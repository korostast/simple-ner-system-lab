# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# GLiNER Configuration
GLINER_MODEL=urchade/gliner_medium-v2.1

# LLM API Configuration
# For llama.cpp server (default):
LLM_API_URL=http://llamacpp:8080/v1
LLM_API_KEY=
LLM_MODEL=unsloth/Qwen3-1.7B-GGUF
LLM_FILE=Qwen3-1.7B-Q8_0.gguf
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300
LLM_TOP_P=0.8

# Application Configuration
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8011

# Frontend API Configuration
# This is used by the frontend to connect to the backend API
# For local development, use: http://localhost:8011/api
# For Docker deployment, use: http://<backend-service-name>:8011/api
API_BASE_URL=http://localhost:8011/api

# Frontend API Configuration
# This is used by the frontend to connect to the backend API
API_BASE_URL=http://localhost:8011/api
